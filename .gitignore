# Archivos y carpetas que deben ser ignorados por git en un proyecto Django

# Entorno virtual
.venv/
venv/
ENV/

# Archivos de base de datos
*.sqlite3
db.sqlite3

# Archivos de migraciones
**/migrations/*.pyc
**/migrations/__pycache__/

# Archivos de Python compilados
*.pyc
__pycache__/

# Archivos de configuración de usuario de VSCode
.vscode/

# Archivos de logs
*.log

# Archivos temporales del sistema operativo
.DS_Store
Thumbs.db

# Archivos de configuración de entorno
.env
.env.*

# Archivos de caché
*.cache

# Archivos de pruebas
.coverage
htmlcov/

# Otros
*.bak
*.swp
*.swo
